# ── Live server environment ────────────────────────────────────────────────────
# Copy this file to .env.live on your server and fill in real values.
# This file is in .gitignore — NEVER commit real keys.

BINANCE_API_KEY=your_real_api_key
BINANCE_API_SECRET=your_real_api_secret

# Set false only when you are ready to trade real funds
PAPER_MODE=true

# Set false only after thorough paper testing
BINANCE_TESTNET=false

DASHBOARD_PORT=3001
WEBHOOK_PORT=3000
LOG_LEVEL=info

# Optional: Telegram notifications
TELEGRAM_TOKEN=
TELEGRAM_CHANNEL_IDS=
